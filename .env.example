IMAGE_NAME=ghcr.io/yangshoulai/tgbot-files:latest
HOST=0.0.0.0
PORT=8787
SQLITE_DB_PATH=/data/tgbot-files.sqlite
PUBLIC_BASE_URL=http://localhost:8787
MAX_FILE_BYTES=20971520
STALE_MULTIPART_UPLOAD_TTL_HOURS=24
CLEANUP_INTERVAL_MINUTES=360
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
TELEGRAM_STORAGE_CHAT_ID=-1001234567890
LINK_SIGNING_SECRET=replace-with-a-long-random-link-signing-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-admin-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-admin-session-secret
TG_CHANNEL_SECRET=replace-with-a-long-random-channel-secret
ARIA2_RPC_URL=http://aria2:6800/jsonrpc
ARIA2_RPC_SECRET=replace-with-a-long-random-aria2-rpc-secret
ARIA2_DOWNLOAD_DIR=/data/aria2/downloads
ARIA2_METADATA_TIMEOUT_SECONDS=30
ARIA2_DOWNLOAD_MAX_BYTES=21474836480
ARIA2_DOWNLOAD_MIN_FREE_BYTES=5368709120
ARIA2_DOWNLOAD_RETENTION_HOURS=24
ARIA2_BT_TRACKERS=
