{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend server for tgbot-files",
  "scripts": {
    "build": "esbuild src/server/server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server/server.mjs",
    "start": "node dist/server/server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.32",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
